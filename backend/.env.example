# =============================================================================
# Adaptix EPCR Service — Environment Configuration Reference
# =============================================================================
# Copy this file to .env and fill in real values before starting the service.
# Variables marked [REQUIRED] must be set; the service will not start without
# them. Variables marked [OPTIONAL] have safe defaults or enable opt-in
# features.
#
# Never commit a populated .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [REQUIRED] asyncpg-compatible PostgreSQL connection string.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
# For Docker Compose local development use the container service name as host.
EPCR_DATABASE_URL=postgresql+asyncpg://epcr_user:changeme@localhost:5432/epcr_db


# -----------------------------------------------------------------------------
# NEMSIS Configuration
# -----------------------------------------------------------------------------

# [REQUIRED] Two-letter US state code that governs NEMSIS dataset rules
# for this agency deployment. Must match an official NEMSIS state abbreviation.
# Example: CA, TX, FL, NY
NEMSIS_STATE_CODE=CA

# [REQUIRED] S3 bucket name where generated NEMSIS XML exports are persisted.
# The bucket must exist and the configured AWS credentials must have
# s3:PutObject / s3:GetObject on this bucket.
NEMSIS_EXPORT_S3_BUCKET=adaptix-nemsis-exports-prod


# -----------------------------------------------------------------------------
# Authentication — JWT (RS256)
# -----------------------------------------------------------------------------

# [REQUIRED] PEM-encoded RS256 public key used to verify inbound JWTs issued
# by the Adaptix identity service. Include the full -----BEGIN PUBLIC KEY-----
# header and footer. For multi-line values use a single-line base64 or
# configure your secrets manager to inject the PEM block via environment.
# Example (single-line base64): base64 -w 0 public.pem
ADAPTIX_JWT_PUBLIC_KEY=


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# [REQUIRED] Comma-separated list of allowed CORS origins for the EPCR API.
# Include the scheme (https://). Wildcard (*) is not accepted in production.
# Example: https://app.adaptixcore.com,https://admin.adaptixcore.com
EPCR_CORS_ALLOW_ORIGINS=https://app.adaptixcore.com


# -----------------------------------------------------------------------------
# AWS Credentials (for S3 export storage)
# -----------------------------------------------------------------------------

# [REQUIRED] AWS region where the NEMSIS export S3 bucket lives.
AWS_REGION=us-east-1

# [REQUIRED] AWS IAM access key ID with write access to NEMSIS_EXPORT_S3_BUCKET.
AWS_ACCESS_KEY_ID=

# [REQUIRED] Secret access key for the IAM identity above.
# Prefer IAM role-based access (instance profile / ECS task role) in production;
# set these only when running outside of a managed AWS environment.
AWS_SECRET_ACCESS_KEY=


# -----------------------------------------------------------------------------
# Event Bus (optional integration)
# -----------------------------------------------------------------------------

# [OPTIONAL] Base URL of the Adaptix Core event bus (webhook/subscription hub).
# When unset the EPCR service runs in standalone mode without publishing domain
# events. Set both URL and TOKEN to enable event publishing.
CORE_EVENT_BUS_URL=

# [OPTIONAL] Bearer token for authenticating outbound requests to the event bus.
CORE_EVENT_BUS_TOKEN=


# -----------------------------------------------------------------------------
# Local Development / CTA Testing Auth Override
# -----------------------------------------------------------------------------

# [OPTIONAL] Set to "true" ONLY in local development or CTA testing environments
# to bypass JWT verification and accept raw X-Tenant-ID / X-User-ID headers.
#
# WARNING: Setting this to "true" in production DISABLES authentication and
# allows any caller to impersonate any tenant. Never set in production.
EPCR_ENABLE_LOCAL_AUTH=false
