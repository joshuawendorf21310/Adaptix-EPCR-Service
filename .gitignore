# Environment — never commit secrets
.env
.env.*
!.env.example

# SQLite databases — never commit runtime artifacts
*.db
*.sqlite
*.sqlite3

# Python build artifacts
build/
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Local test outputs
htmlcov/
.coverage
coverage.xml
.local/

# Local CTA/NEMSIS harness artifacts
nemsis_test/logs/*.json
nemsis_test/output/
artifact/cta/testing-portal/runs/

# Local proof JWT keys - generate per developer, never commit real keys
jwt_priv.pem
jwt_pub.pem

# Runtime artifacts (not committed)
artifact/cta/parsed-result.json
backend/artifact/validation/schematron_cache/

# Scratch / debug files — never commit ad-hoc exploration outputs
*.log
*.out
*.patch
_*.py
_*.json
_*.txt
*.tmp
.tmp_*
.local-*
.cta_*
.element_enum_*

# One-off JSON/XML dumps from local testing
art*.json
resp_*.json
login*.json
export_*.xml
export_*.json
export_resp.*
token.txt
headers*.txt
ready.json
val.json
validate.json
gen.json
exp.json
openapi.json
openapi_*.json
build.log
chart_get.out

# ECS task-definition scratch files
epcr-taskdef*.json
