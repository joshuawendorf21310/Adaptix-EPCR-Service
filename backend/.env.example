# EPCR Service Environment Variables
# Classification: required_for_local_boot | required_for_production | optional_provider | credential_gated

# required_for_local_boot
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/epcr_db
SECRET_KEY=your-secret-key-change-in-production

# required_for_production
CORE_SERVICE_URL=http://adaptix-core:8000
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256

# optional_provider - credential_gated
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
METRIPORT_API_KEY=
METRIPORT_BASE_URL=https://api.metriport.com

# required_for_tests
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/epcr_test_db

# must_fail_if_missing_in_production
# DATABASE_URL, CORE_SERVICE_URL, JWT_PUBLIC_KEY

# must_degrade_gracefully_if_missing
# S3_BUCKET_NAME, METRIPORT_API_KEY
