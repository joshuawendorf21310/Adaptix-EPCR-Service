# epcr — ePCR clinical charting, NEMSIS 3.5.1, assessment, QA, and export domain
# Copy to .env and fill in values before running.

# ────────────────────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────────────────────

# Required: PostgreSQL asyncpg connection string for the ePCR domain database.
# Service will not start without this variable.
EPCR_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/epcr

# Optional: Legacy alias for EPCR_DATABASE_URL — accepted if EPCR_DATABASE_URL is not set.
# CARE_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/epcr

# ────────────────────────────────────────────────────────────────────────────
# Authentication
# ────────────────────────────────────────────────────────────────────────────

# Required: PEM-encoded RSA or EC public key used to verify Adaptix gateway-issued JWT tokens.
# Provided by the core/auth service.
ADAPTIX_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nyour-public-key-here\n-----END PUBLIC KEY-----

# ────────────────────────────────────────────────────────────────────────────
# NEMSIS 3.5.1 — state submission (SOAP)
# ────────────────────────────────────────────────────────────────────────────

# Required for state submissions: SOAP endpoint URL for the state NEMSIS submission target.
NEMSIS_STATE_ENDPOINT_URL=https://your-state-nemsis-endpoint/submission

# Required for state submissions: SOAP username credential for state NEMSIS submission.
NEMSIS_SOAP_USERNAME=your-nemsis-soap-username

# Required for state submissions: SOAP password credential for state NEMSIS submission.
NEMSIS_SOAP_PASSWORD=your-nemsis-soap-password

# ────────────────────────────────────────────────────────────────────────────
# NEMSIS 3.5.1 — TAC scenario compliance
# ────────────────────────────────────────────────────────────────────────────

# Required for TAC submissions: TAC scenario compliance studio endpoint URL.
# Falls back to TAC_ENDPOINT_URL if not set.
NEMSIS_TAC_ENDPOINT_URL=https://your-tac-endpoint/scenario

# Optional alias for NEMSIS_TAC_ENDPOINT_URL.
# TAC_ENDPOINT_URL=https://your-tac-endpoint/scenario

# Optional: TAC-specific SOAP username. Falls back to NEMSIS_SOAP_USERNAME if not set.
# NEMSIS_TAC_USERNAME=your-tac-username

# Optional: TAC-specific SOAP password. Falls back to NEMSIS_SOAP_PASSWORD if not set.
# NEMSIS_TAC_PASSWORD=your-tac-password

# Optional: NEMSIS schema version string for TAC payloads.
# Default: 3.5.1.240301
# NEMSIS_SCHEMA_VERSION=3.5.1.240301

# Optional: Software creator field for NEMSIS TAC payloads.
# Default: FusionEMSQuantum
# NEMSIS_SOFTWARE_CREATOR=FusionEMSQuantum

# Optional: Software name field for NEMSIS TAC payloads.
# Default: Adaptix ePCR
# NEMSIS_SOFTWARE_NAME=Adaptix ePCR

# Optional: Software version field for NEMSIS TAC payloads.
# Default: 1.0.0
# NEMSIS_SOFTWARE_VERSION=1.0.0

# ────────────────────────────────────────────────────────────────────────────
# NEMSIS 3.5.1 — schema validation
# ────────────────────────────────────────────────────────────────────────────

# Required for local XSD validation: filesystem path to the NEMSIS 3.5.1 XSD schema file.
NEMSIS_XSD_PATH=/app/nemsis/NEMSIS_3.5.1_240301.xsd

# Required for local Schematron validation: filesystem path to the NEMSIS Schematron rules file.
NEMSIS_SCHEMATRON_PATH=/app/nemsis/NEMSIS_3.5.1_240301.sch

# ────────────────────────────────────────────────────────────────────────────
# S3 storage
# ────────────────────────────────────────────────────────────────────────────

# Required: General-purpose S3 bucket used as fallback for submission, export, and pack storage.
FILES_S3_BUCKET=your-s3-bucket-name

# Optional: S3 bucket for NEMSIS submission artifacts. Falls back to FILES_S3_BUCKET.
# NEMSIS_SUBMISSION_S3_BUCKET=your-nemsis-submission-bucket

# Optional: S3 key prefix for NEMSIS submission objects.
# Default: nemsis/submissions
# NEMSIS_SUBMISSION_S3_PREFIX=nemsis/submissions

# Optional: S3 bucket for NEMSIS export XML files. Falls back to FILES_S3_BUCKET.
# NEMSIS_EXPORT_S3_BUCKET=your-nemsis-export-bucket

# Optional: S3 bucket for NEMSIS resource pack storage. Falls back to FILES_S3_BUCKET.
# NEMSIS_PACK_S3_BUCKET=your-nemsis-pack-bucket

# Optional: S3 key prefix for NEMSIS resource pack objects.
# Default: nemsis/packs
# NEMSIS_PACK_S3_PREFIX=nemsis/packs
